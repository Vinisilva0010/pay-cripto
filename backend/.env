
# --- CONFIGURAÇÕES DA BLOCKCHAIN (REDE DE TESTES SEPOLIA) ---
# RPC URL: É o endereço do "Carteiro" que leva e traz dados da Blockchain.
# Estamos usando um RPC público da Sepolia para começar (Grátis).
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- CONFIGURAÇÕES DO SERVIDOR ---
HOST=127.0.0.1
PORT=8000


# A carteira da Loja (Para onde o dinheiro vai)
# Pode usar essa de teste abaixo ou colocar a sua pública da MetaMask
MERCHANT_WALLET=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045

DATABASE_URL=sqlite:zanvexis.db
